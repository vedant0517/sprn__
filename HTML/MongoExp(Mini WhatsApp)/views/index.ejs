<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="layout">
        <header class="hero">
            <h3>All Chats</h3>
            <form method="GET" action="/chats/new">
                <button>New Chat</button>
            </form>
            <p>Simple conversations in a timeless layout.</p>
        </header>

        <% for(let chat of chats){ %>
        <article class="chat">
            <p class="meta">From <span><%= chat.from %></span></p>
            <div class="msg">
                <p><%= chat.msg %></p>
            </div>
            <div class="chat-actions">
                <form method="GET" action="/chats/<%=chat._id %>">
                    <button type="submit" class="action-btn">Show</button>
                </form>
                <form method="GET" action="/chats/<%=chat._id %>/edit">
                    <button type="submit" class="action-btn">Edit</button>
                </form>
                <form method="POST" action="/chats/<%=chat._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this chat?');">
                    <button type="submit" class="action-btn danger-btn">Delete</button>
                </form>
            </div>
            <p class="meta">Received by <span><%= chat.to %></span></p>
            <p class="timestamp">&#128336; <%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %> &mdash; <%= chat.created_at.toString().split(" ")[4] %></p>
            <p class="timestamp">Last updated: <%= (chat.updated_at || chat.created_at).toString().split(" ").slice(0,4).join(" ") %> &mdash; <%= (chat.updated_at || chat.created_at).toString().split(" ")[4] %></p>
        </article>
        <% } %>
    </main>

</body>
</html>

